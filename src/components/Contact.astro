---
---
<section id="contato" class="py-20 lg:py-32 relative">
  <!-- Background glow -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="hero-orb w-[600px] h-[600px] bg-[#00ff88] opacity-[0.04] top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2"></div>
  </div>

  <div class="max-w-7xl mx-auto px-6 lg:px-12 relative z-10">

    <!-- Big CTA -->
    <div class="text-center mb-12 lg:mb-20">
      <div class="reveal mb-6">
        <span class="text-[#00ff88] text-xs font-mono tracking-[0.4em] uppercase">05 / Contato</span>
      </div>
      <div class="reveal delay-100">
        <h2 class="text-[clamp(2.2rem,8vw,10rem)] font-black leading-[0.85] tracking-tight text-white">
          VAMOS<br/>
          <span class="gradient-text">CONSTRUIR</span><br/>
          <span class="text-white/10">ALGO.</span>
        </h2>
      </div>
      <div class="reveal delay-200 mt-8 max-w-lg mx-auto">
        <p class="text-base text-white/40 leading-relaxed">
          Product Manager Senior disponível para oportunidades em Fintech, Payments e Plataformas Digitais. CLT, PJ ou projetos estratégicos.
        </p>
      </div>
    </div>

    <!-- Contact cards -->
    <div class="grid md:grid-cols-3 gap-6 mb-16" data-stagger>
      <!-- Email -->
      <a href="mailto:gustavo.henrique16@outlook.com" class="reveal card-hover glow group p-6 bg-[#0d0d0d] border border-white/5 rounded-2xl hover:border-white/10 transition-all duration-500 flex flex-col gap-4" data-hover>
        <div class="w-10 h-10 rounded-xl bg-[#00ff88]/10 border border-[#00ff88]/20 flex items-center justify-center">
          <svg width="20" height="20" fill="none" stroke="#00ff88" stroke-width="1.8">
            <rect x="2" y="4" width="16" height="13" rx="2"/>
            <path d="M2 7l8 5 8-5"/>
          </svg>
        </div>
        <div>
          <div class="text-xs text-white/30 uppercase tracking-widest mb-1">Email</div>
          <div class="text-sm font-medium text-white/70 group-hover:text-white transition-colors break-all">gustavo.henrique16@outlook.com</div>
        </div>
        <div class="mt-auto flex items-center gap-2 text-[#00ff88]">
          <span class="text-xs font-semibold tracking-wider uppercase">Entrar em contato</span>
          <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M3 7h8M7 3l4 4-4 4"/></svg>
        </div>
      </a>

      <!-- LinkedIn -->
      <a href="https://linkedin.com/in/gustavobordotti" target="_blank" class="reveal card-hover glow group p-6 bg-[#0d0d0d] border border-white/5 rounded-2xl hover:border-white/10 transition-all duration-500 flex flex-col gap-4" data-hover>
        <div class="w-10 h-10 rounded-xl bg-[#0066ff]/10 border border-[#0066ff]/20 flex items-center justify-center">
          <svg width="20" height="20" fill="none" stroke="#0066ff" stroke-width="1.8">
            <rect x="2" y="2" width="16" height="16" rx="3"/>
            <path d="M6 9v6M6 6v.01M10 9v6M10 12a3 3 0 016 0v3"/>
          </svg>
        </div>
        <div>
          <div class="text-xs text-white/30 uppercase tracking-widest mb-1">LinkedIn</div>
          <div class="text-sm font-medium text-white/70 group-hover:text-white transition-colors">linkedin.com/in/gustavobordotti</div>
        </div>
        <div class="mt-auto flex items-center gap-2 text-[#0066ff]">
          <span class="text-xs font-semibold tracking-wider uppercase">Ver perfil</span>
          <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M3 7h8M7 3l4 4-4 4"/></svg>
        </div>
      </a>

      <!-- WhatsApp -->
      <a href="https://wa.me/5511986502540?text=Ol%C3%A1%20Gustavo%2C%20vi%20seu%20portf%C3%B3lio%20e%20gostaria%20de%20conversar." target="_blank" class="reveal card-hover glow group p-6 bg-[#0d0d0d] border border-white/5 rounded-2xl hover:border-white/10 transition-all duration-500 flex flex-col gap-4" data-hover>
        <div class="w-10 h-10 rounded-xl bg-[#25D366]/10 border border-[#25D366]/20 flex items-center justify-center">
          <svg width="20" height="20" fill="none" stroke="#25D366" stroke-width="1.8">
            <path d="M3 21l1.65-3.8a9 9 0 1 1 3.4 2.9L3 21"/>
            <path d="M9 10c0 .6.4 2 2 3s2.4 1 3 1"/>
          </svg>
        </div>
        <div>
          <div class="text-xs text-white/30 uppercase tracking-widest mb-1">WhatsApp</div>
          <div class="text-sm font-medium text-white/70 group-hover:text-white transition-colors">(11) 98650-2540</div>
        </div>
        <div class="mt-auto flex items-center gap-2 text-[#25D366]">
          <span class="text-xs font-semibold tracking-wider uppercase">Abrir conversa</span>
          <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M3 7h8M7 3l4 4-4 4"/></svg>
        </div>
      </a>
    </div>

    <!-- Divider -->
    <div class="section-divider my-16"></div>

    <!-- Footer -->
    <div class="reveal flex flex-col md:flex-row items-center justify-between gap-6 text-xs text-white/20">
      <div class="font-bold tracking-[0.3em] uppercase text-[#00ff88]/40">
        Gustavo Henrique · PM Senior
      </div>
      <div class="text-center">
        Cotia, SP · Brasil · <span class="font-mono">{new Date().getFullYear()}</span>
      </div>
      <div class="font-mono">
        Payments · Fintech · Plataformas Digitais
      </div>
    </div>

  </div>
</section>

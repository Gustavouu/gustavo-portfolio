---
---
<nav class="nav-blur fixed top-0 left-0 right-0 z-50">
  <div class="max-w-7xl mx-auto px-6 lg:px-12 py-5 flex items-center justify-between">
    <a href="#hero" class="text-sm font-bold tracking-[0.3em] uppercase text-[#00ff88]" data-hover>
      GH<span class="text-white/30">.</span>
    </a>
    <div class="hidden md:flex items-center gap-10">
      {[['#sobre','Sobre'],['#experiencia','Experiência'],['#cases','Cases'],['#projetos','Projetos'],['#skills','Skills'],['#contato','Contato']].map(([href, label]) => (
        <a href={href} class="text-xs font-medium tracking-[0.15em] uppercase text-white/50 hover:text-white transition-colors duration-300" data-hover>
          {label}
        </a>
      ))}
    </div>
    <a href="mailto:gustavo.henrique16@outlook.com" class="hidden md:flex items-center gap-2 px-5 py-2.5 border border-[#00ff88]/30 text-[#00ff88] text-xs font-semibold tracking-widest uppercase rounded-full hover:bg-[#00ff88] hover:text-black transition-all duration-300" data-hover>
      Contato
    </a>
    <!-- Mobile menu button -->
    <button id="menu-btn" class="md:hidden flex items-center justify-center w-11 h-11 text-white/70 hover:text-white" data-hover>
      <svg width="28" height="28" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="4" y1="7" x2="24" y2="7"/>
        <line x1="4" y1="14" x2="24" y2="14"/>
        <line x1="4" y1="21" x2="24" y2="21"/>
      </svg>
    </button>
  </div>
</nav>

<!-- Mobile drawer -->
<div id="mobile-menu" class="fixed inset-0 z-40 bg-[#080808]/95 backdrop-blur-xl flex flex-col items-center justify-center gap-8 translate-x-full transition-transform duration-500 md:hidden">
  <button id="close-menu" class="absolute top-6 right-6 text-white/70">
    <svg width="28" height="28" fill="none" stroke="currentColor" stroke-width="2">
      <line x1="4" y1="4" x2="24" y2="24"/>
      <line x1="24" y1="4" x2="4" y2="24"/>
    </svg>
  </button>
  {[['#sobre','Sobre'],['#experiencia','Experiência'],['#cases','Cases'],['#projetos','Projetos'],['#skills','Skills'],['#contato','Contato']].map(([href, label]) => (
    <a href={href} class="mobile-link text-2xl font-bold tracking-wider text-white/80 hover:text-[#00ff88] transition-colors" data-hover>
      {label}
    </a>
  ))}
</div>

<script>
  const btn = document.getElementById('menu-btn');
  const menu = document.getElementById('mobile-menu');
  const closeBtn = document.getElementById('close-menu');

  btn?.addEventListener('click', () => menu?.classList.remove('translate-x-full'));
  closeBtn?.addEventListener('click', () => menu?.classList.add('translate-x-full'));
  document.querySelectorAll('.mobile-link').forEach(link => {
    link.addEventListener('click', () => menu?.classList.add('translate-x-full'));
  });
</script>

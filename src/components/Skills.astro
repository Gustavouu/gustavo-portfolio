---
const skillGroups = [
  {
    title: 'Product & Strategy',
    color: '#00ff88',
    skills: [
      { name: 'Product Strategy & Roadmap', level: 95 },
      { name: 'Product Discovery', level: 90 },
      { name: 'OKRs & Métricas de Produto', level: 88 },
      { name: 'Business Case & P&L', level: 85 },
      { name: 'A/B Testing & Experimentação', level: 82 },
    ],
  },
  {
    title: 'Payments & Fintech',
    color: '#0066ff',
    skills: [
      { name: 'PIX · SPB/SPI', level: 95 },
      { name: 'Adquirência (captura→settlement)', level: 93 },
      { name: 'BaaS · PaaS · BIN/IIN', level: 88 },
      { name: 'SoftPOS · Tap on Phone · PCI', level: 85 },
      { name: 'CNAB · Payment Links', level: 80 },
    ],
  },
  {
    title: 'Data & Analytics',
    color: '#ff6b35',
    skills: [
      { name: 'Power BI · Dashboards', level: 85 },
      { name: 'SQL · PostgreSQL', level: 80 },
      { name: 'Data Modeling · DW', level: 75 },
      { name: 'Behavioral Analytics', level: 78 },
      { name: 'Product Analytics', level: 82 },
    ],
  },
  {
    title: 'Plataformas & Integrações',
    color: '#a855f7',
    skills: [
      { name: 'APIs REST · Arquitetura funcional', level: 80 },
      { name: 'Celcoin · Efi · Lago', level: 75 },
      { name: 'n8n · Automações', level: 70 },
      { name: 'Jira · Azure DevOps', level: 90 },
      { name: 'Confluence · Notion', level: 88 },
    ],
  },
];

const certs = [
  { name: 'CSPO', full: 'Certified Scrum Product Owner', org: 'Scrum Alliance', color: '#00ff88' },
  { name: 'PM3', full: '9 Formações: Discovery, Analytics, Roadmap, Design, Marketing, Métricas, Backlog', org: 'PM3', color: '#0066ff' },
  { name: 'PUC-Rio', full: 'Advanced Analytics & Data Architecture · Data Modeling, DW, Data Lake', org: 'PUC-RJ', color: '#ff6b35' },
  { name: 'Lean Six Sigma', full: 'Yellow Belt', org: 'FM2S', color: '#eab308' },
  { name: 'Scrum Master', full: 'SMC · SFPC · OKR', org: 'CertiProf', color: '#a855f7' },
  { name: 'BIFPC', full: 'Business Intelligence Foundations', org: 'CertiProf', color: '#06b6d4' },
];
---
<section id="skills" class="py-32 relative skills-section">
  <div class="max-w-7xl mx-auto px-6 lg:px-12">

    <!-- Header -->
    <div class="reveal mb-20">
      <div class="flex items-center gap-4 mb-6">
        <span class="text-[#00ff88] text-xs font-mono tracking-[0.4em] uppercase">04 / Skills</span>
        <div class="h-px flex-1 max-w-[80px] bg-[#00ff88]/20"></div>
      </div>
      <h2 class="text-[clamp(2.5rem,6vw,5rem)] font-black leading-[0.95] tracking-tight text-white">
        ARSENAL<br/>
        <span class="gradient-text">TÉCNICO.</span>
      </h2>
    </div>

    <!-- Skills grid -->
    <div class="grid md:grid-cols-2 gap-8 mb-20" data-stagger>
      {skillGroups.map((group, gi) => (
        <div class="reveal p-8 bg-[#0d0d0d] border border-white/5 rounded-2xl">
          <h3 class="text-sm font-bold tracking-[0.2em] uppercase mb-6" style={`color: ${group.color}`}>
            {group.title}
          </h3>
          <div class="space-y-5">
            {group.skills.map(s => (
              <div>
                <div class="flex justify-between items-center mb-2">
                  <span class="text-sm text-white/60">{s.name}</span>
                  <span class="text-xs font-mono" style={`color: ${group.color}80`}>{s.level}%</span>
                </div>
                <div class="progress-bar">
                  <div class="progress-fill" style={`--target-width: ${s.level / 100}; background: linear-gradient(90deg, ${group.color}, ${group.color}80)`}></div>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- Certifications -->
    <div class="reveal mb-8">
      <h3 class="text-xs font-mono tracking-[0.4em] uppercase text-white/30 mb-8">Certificações & Formação</h3>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4" data-stagger>
      {certs.map(c => (
        <div class="reveal card-hover p-5 bg-[#0d0d0d] border border-white/5 rounded-xl hover:border-white/10 transition-all duration-300 group">
          <div class="flex items-start justify-between mb-3">
            <span class="text-lg font-black text-white group-hover:opacity-80 transition-opacity">{c.name}</span>
            <span class="text-[10px] text-white/30 mt-1">{c.org}</span>
          </div>
          <p class="text-xs text-white/40 leading-relaxed">{c.full}</p>
          <div class="mt-3 h-0.5 rounded-full opacity-30" style={`background: ${c.color}`}></div>
        </div>
      ))}
    </div>

    <!-- Education -->
    <div class="reveal mt-16 p-8 bg-[#0d0d0d] border border-white/5 rounded-2xl">
      <h3 class="text-xs font-mono tracking-[0.4em] uppercase text-white/30 mb-8">Educação Formal</h3>
      <div class="grid md:grid-cols-3 gap-6">
        {[
          { course: 'Engenharia de Software', inst: 'PUC-Rio', status: 'Cursando · Pós-graduação', color: '#00ff88' },
          { course: 'Gestão Ágil de Projetos', inst: 'XP Educação', status: 'Concluído · Pós-graduação', color: '#0066ff' },
          { course: 'Gestão Financeira', inst: 'Universidade Nove de Julho', status: 'Concluído · Graduação', color: '#ff6b35' },
        ].map(e => (
          <div class="space-y-1">
            <div class="text-sm font-bold text-white">{e.course}</div>
            <div class="text-xs text-white/50">{e.inst}</div>
            <div class="text-xs font-medium" style={`color: ${e.color}`}>{e.status}</div>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>

<style>
  .progress-fill.animated {
    transform: scaleX(var(--target-width, 0)) !important;
  }
</style>

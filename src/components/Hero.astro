---
---
<section id="hero" class="relative min-h-screen flex flex-col justify-center overflow-hidden pt-20">
  <!-- Orbs -->
  <div class="hero-orb w-[300px] h-[300px] lg:w-[500px] lg:h-[500px] bg-[#00ff88] opacity-[0.06] top-[-50px] right-[-80px]"></div>
  <div class="hero-orb w-[250px] h-[250px] lg:w-[400px] lg:h-[400px] bg-[#0066ff] opacity-[0.05] bottom-[0px] left-[-80px]" style="animation-delay: 3s;"></div>

  <div class="max-w-7xl mx-auto px-6 lg:px-12 w-full">
    <div class="grid lg:grid-cols-2 gap-16 items-center">

      <!-- Left: Text -->
      <div class="space-y-10 z-10 relative">
        <!-- Badge -->
        <div class="reveal delay-100">
          <span class="tag">Product Manager Senior</span>
        </div>

        <!-- Headline -->
        <div class="reveal delay-200">
          <h1 class="text-[clamp(2.8rem,10vw,8rem)] font-black leading-[0.9] tracking-[-0.04em] text-white">
            GUSTAVO<br/>
            <span class="gradient-text glitch-text" data-text="HENRIQUE">HENRIQUE</span>
          </h1>
        </div>

        <!-- Tagline -->
        <div class="reveal delay-300">
          <p class="text-lg text-white/50 font-light leading-relaxed max-w-md">
            PM Senior com histórico em <span class="text-[#00ff88] font-medium">Fintech e Payments de alta escala</span>.
            Construo produtos que crescem, defendo P&L e lidero roadmaps que chegam na mesa executiva:
            PIX, Adquirência, BaaS, Plataformas Digitais.
          </p>
        </div>

        <!-- Stats row -->
        <div class="reveal delay-400 grid grid-cols-3 gap-3 pt-4">
          {[
            { num: '+330%', label: 'Crescimento de receita' },
            { num: '198k', label: 'Sellers ativos' },
            { num: '~20%', label: 'Redução de falhas' },
          ].map(s => (
            <div class="space-y-1">
              <div class="text-2xl lg:text-3xl font-black text-[#00ff88]">{s.num}</div>
              <div class="text-[10px] lg:text-xs text-white/40 leading-tight">{s.label}</div>
            </div>
          ))}
        </div>

        <!-- CTAs -->
        <div class="reveal delay-500 flex flex-col sm:flex-row gap-3">
          <a href="#experiencia" class="magnetic-btn glow flex items-center justify-center gap-3 px-6 py-4 bg-[#00ff88] text-black text-sm font-bold tracking-widest uppercase rounded-full hover:scale-105 transition-all duration-300" data-hover>
            Ver Experiência
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M3 8h10M9 4l4 4-4 4"/>
            </svg>
          </a>
          <a href="https://linkedin.com/in/gustavobordotti" target="_blank" class="magnetic-btn flex items-center justify-center gap-3 px-6 py-4 border border-white/20 text-white text-sm font-semibold tracking-widest uppercase rounded-full hover:border-[#00ff88]/50 hover:text-[#00ff88] transition-all duration-300" data-hover>
            LinkedIn
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="2" y="2" width="12" height="12" rx="2"/>
              <path d="M5 7v4M5 5v.01M8 7v4M8 9a2 2 0 014 0v2"/>
            </svg>
          </a>
        </div>

        <!-- Social links -->
        <div class="reveal delay-600 flex flex-wrap items-center gap-4">
          <span class="text-xs text-white/30 uppercase tracking-widest">Links</span>
          <div class="h-px w-8 bg-white/10"></div>
          <a href="https://linkedin.com/in/gustavobordotti" target="_blank" class="text-white/40 hover:text-[#00ff88] transition-colors text-xs font-medium tracking-wider uppercase" data-hover>LinkedIn</a>
          <a href="mailto:gustavo.henrique16@outlook.com" class="text-white/40 hover:text-[#00ff88] transition-colors text-xs font-medium tracking-wider uppercase" data-hover>Email</a>
          <a href="tel:+5511986502540" class="text-white/40 hover:text-[#00ff88] transition-colors text-xs font-medium tracking-wider uppercase" data-hover>Tel</a>
        </div>
      </div>

      <!-- Right: Photo + floating cards -->
      <div class="relative h-[600px] hidden lg:flex items-center justify-center">
        <!-- Photo container -->
        <div class="reveal-right relative w-[340px] h-[480px]">
          <!-- Decorative border -->
          <div class="absolute inset-0 border border-[#00ff88]/20 rounded-2xl translate-x-4 translate-y-4"></div>
          <div class="scanline w-full h-full rounded-2xl overflow-hidden bg-[#111] border border-white/5">
            <img
              src="/images/hero-photo.jpg"
              alt="Gustavo Henrique"
              class="w-full h-full object-cover object-center grayscale hover:grayscale-0 transition-all duration-700"
              onerror="this.style.display='none'; this.parentElement.style.background='linear-gradient(135deg, #111 0%, #1a1a1a 100%)'"
            />
            <!-- Fallback when no photo -->
            <div class="absolute inset-0 flex flex-col items-center justify-center text-white/20 text-sm font-mono" id="photo-fallback">
              <div class="text-6xl font-black text-[#00ff88]/20 mb-4">GH</div>
              <div class="text-xs text-white/20">adicione hero-photo.jpg</div>
              <div class="text-xs text-white/20">em public/images/</div>
            </div>
          </div>
          <!-- Green gradient overlay bottom -->
          <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-[#080808] to-transparent rounded-b-2xl pointer-events-none"></div>
        </div>

        <!-- Floating badge: Location -->
        <div class="float-badge absolute top-[60px] left-[-20px] bg-[#111] border border-white/10 rounded-xl px-4 py-3 text-xs" style="animation-delay:0s">
          <div class="text-white/40">Localização</div>
          <div class="text-white font-semibold mt-0.5">Cotia, SP · Brasil</div>
        </div>

        <!-- Floating badge: Current role -->
        <div class="float-badge absolute top-[200px] right-[-40px] bg-[#111] border border-[#00ff88]/20 rounded-xl px-4 py-3 text-xs" style="animation-delay:1.5s">
          <div class="flex items-center gap-2 mb-1">
            <div class="w-2 h-2 bg-[#00ff88] rounded-full animate-pulse"></div>
            <span class="text-[#00ff88] font-semibold">Disponível</span>
          </div>
          <div class="text-white/60">Open to opportunities</div>
        </div>

        <!-- Floating badge: Experience -->
        <div class="float-badge absolute bottom-[120px] left-[-30px] bg-[#0066ff]/10 border border-[#0066ff]/20 rounded-xl px-4 py-3 text-xs" style="animation-delay:2.5s">
          <div class="text-white/40">Expertise</div>
          <div class="text-[#0066ff] font-semibold mt-0.5">Fintech & Payments</div>
        </div>
      </div>

    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 animate-bounce">
    <span class="text-[10px] text-white/30 uppercase tracking-widest">Scroll</span>
    <svg width="16" height="24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-white/20">
      <rect x="2" y="2" width="12" height="20" rx="6"/>
      <circle cx="8" cy="8" r="2" fill="currentColor"/>
    </svg>
  </div>
</section>

<style>
  #photo-fallback { display: none; }
  img[style*="display:none"] + #photo-fallback { display: flex; }
</style>
